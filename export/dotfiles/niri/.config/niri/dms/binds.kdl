binds {
    Mod+D allow-inhibiting=false hotkey-overlay-title="App Launcher: Toggle" { spawn "dms" "ipc" "call" "spotlight" "toggle"; }
    Mod+L allow-inhibiting=false hotkey-overlay-title="Lock Screen" { spawn "dms" "ipc" "call" "lock" "lock"; }
    Mod+M allow-inhibiting=false hotkey-overlay-title="Control Center: Toggle" { spawn "dms" "ipc" "call" "control-center" "toggle"; }
    Mod+E allow-inhibiting=false hotkey-overlay-title="Files" { spawn "nautilus"; }
}
