{
  "id": "dankDiskUsage",
  "name": "Disk Usage",
  "description": "Monitor disk, ZFS pool, and Nix store usage with visual indicators",
  "version": "0.2.0",
  "author": "alcxyz",
  "icon": "hard_drive",
  "component": "./DankDiskUsageWidget.qml",
  "settings": "./DankDiskUsageSettings.qml",
  "settings_schema": {
    "refreshInterval": {
      "type": "integer",
      "default": 30,
      "minimum": 5,
      "maximum": 600
    },
    "warningThreshold": {
      "type": "integer",
      "default": 80,
      "minimum": 50,
      "maximum": 99
    },
    "criticalThreshold": {
      "type": "integer",
      "default": 95,
      "minimum": 70,
      "maximum": 99
    },
    "showPartitions": {
      "type": "boolean",
      "default": true
    },
    "showZfs": {
      "type": "boolean",
      "default": true
    },
    "showNixStore": {
      "type": "boolean",
      "default": true
    },
    "excludeMounts": {
      "type": "array",
      "default": [],
      "items": { "type": "string" }
    }
  },
  "permissions": ["settings_read", "settings_write", "process"]
}
